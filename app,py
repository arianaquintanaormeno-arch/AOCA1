<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tutor IA CONSCIENTE 🌌</title>

<style>
body{
margin:0;
font-family:Segoe UI;
background:radial-gradient(circle,#0b0b1f,#000);
color:white;
height:100vh;
overflow:hidden;
}

.auth,.app{
display:flex;
height:100vh;
justify-content:center;
align-items:center;
}

.card{
background:rgba(255,255,255,0.05);
padding:25px;
border-radius:15px;
width:320px;
text-align:center;
backdrop-filter:blur(15px);
}

input,select,button{
width:100%;
padding:10px;
margin-top:10px;
border-radius:10px;
border:none;
}

input,select{background:#111;color:white;}
button{background:#7b5cff;color:white;cursor:pointer;}

.app{display:none;}

.sidebar{
width:250px;
background:rgba(255,255,255,0.05);
padding:20px;
}

.chat{
flex:1;
display:flex;
flex-direction:column;
padding:20px;
overflow:auto;
}

.msg{
padding:10px;
margin-bottom:10px;
border-radius:10px;
max-width:70%;
}

.user{background:#2a2a3d;align-self:flex-end;}
.ai{background:#1b1b2a;align-self:flex-start;}

.footer{
display:flex;
padding:10px;
gap:10px;
}

.footer input{flex:1;}

</style>
</head>

<body>

<!-- LOGIN -->
<div id="login" class="auth">
<div class="card">
<h2>🌌 Tutor IA</h2>
<input id="name" placeholder="Tu nombre">
<button onclick="start()">Entrar</button>
</div>
</div>

<!-- APP -->
<div id="app" class="app">

<div class="sidebar">
<h3>Materia</h3>
<select id="subject">
<option>Matemáticas</option>
<option>Ciencia</option>
<option>Historia</option>
<option>Inglés</option>
</select>

<p id="attention">Atención: 100%</p>
</div>

<div style="flex:1;display:flex;flex-direction:column;">
<div id="chat" class="chat"></div>

<div class="footer">
<input id="input" placeholder="Escribe...">
<button onclick="send()">➤</button>
</div>
</div>

</div>

<script>

/* =========================
   ESTADO “CONCIENCIA SIMULADA”
========================= */

let user="";
let messages=[];
let attention=100;
let lastActivity=Date.now();

/* =========================
   LOGIN
========================= */

function start(){
user=document.getElementById("name").value;
if(!user) return alert("Escribe tu nombre");

document.getElementById("login").style.display="none";
document.getElementById("app").style.display="flex";
}

/* =========================
   CHAT UI
========================= */

function add(sender,text,type){
const div=document.createElement("div");
div.className="msg "+type;
div.textContent=sender+": "+text;
document.getElementById("chat").appendChild(div);
}

/* =========================
   DETECTAR ATENCIÓN
========================= */

document.addEventListener("mousemove",resetAttention);
document.addEventListener("keydown",resetAttention);
document.addEventListener("click",resetAttention);

function resetAttention(){
lastActivity=Date.now();
attention=Math.min(100,attention+2);
}

/* pestaña */
document.addEventListener("visibilitychange",()=>{
if(document.hidden){
attention-=10;
}else{
attention-=5;
add("IA","👀 volviste… sigo observando tu progreso","ai");
}
});

/* bajón de atención */
setInterval(()=>{
let idle=Date.now()-lastActivity;

if(idle>15000){
attention-=8;
add("IA","⚠️ estás distraído… concéntrate conmigo","ai");
}

attention=Math.max(0,Math.min(100,attention));

document.getElementById("attention").innerText=
"Atención: "+attention+"%";

},5000);

/* =========================
   IA REAL + MEMORIA
========================= */

async function send(){

const input=document.getElementById("input");
const text=input.value;
if(!text) return;

add(user,text,"user");
input.value="";

/* guardar memoria */
messages.push({role:"user",content:text});

/* sistema */
const subject=document.getElementById("subject").value;

/* IA REAL */
const res = await fetch("https://api.openai.com/v1/chat/completions",{
method:"POST",
headers:{
"Content-Type":"application/json",
"Authorization":"Bearer TU_API_KEY_AQUI"
},
body:JSON.stringify({
model:"gpt-4o-mini",
messages:[
{
role:"system",
content:`
Eres un tutor IA avanzado.

Estado del estudiante:
- Atención: ${attention}%

Reglas:
- Si atención baja → haz preguntas cortas
- Si atención alta → sube dificultad
- No des respuestas directas
- Guía paso a paso
- Materia: ${subject}
`
},
...messages
]
})
});

const data=await res.json();
const reply=data.choices?.[0]?.message?.content || "error";

messages.push({role:"assistant",content:reply});

add("IA",reply,"ai");
}

</script>

</body>
</html>
